<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="#D8F3DC" /> <!-- Light Green Highlight -->
        </shape>
    </item>
    <item android:left="-2dp" android:top="-2dp" android:bottom="-2dp">
        <shape>
            <stroke android:width="1dp" android:color="#DEE2E6" />
        </shape>
    </item>
    <item android:left="-2dp" android:top="-2dp" android:right="-2dp">
        <shape>
            <stroke android:width="1dp" android:color="#DEE2E6" />
        </shape>
    </item>
</layer-list>