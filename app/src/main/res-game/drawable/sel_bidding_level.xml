<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <!-- Wypełnienie (Ciemnozielone) -->
            <item>
                <shape>
                    <solid android:color="#1A3026" />
                    <corners android:topLeftRadius="8dp" android:topRightRadius="8dp" />
                </shape>
            </item>
            <!-- Kontur: Góra, Lewo, Prawo (Dół ukryty przez -1dp) -->
            <item android:bottom="-1dp">
                <shape>
                    <stroke android:width="1dp" android:color="#33000000" /> <!-- Delikatna czerń 20% -->
                    <corners android:topLeftRadius="8dp" android:topRightRadius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <!-- Wypełnienie (Jasnozielone) -->
            <item>
                <shape>
                    <solid android:color="#D5D9A5" />
                    <corners android:topLeftRadius="8dp" android:topRightRadius="8dp" />
                </shape>
            </item>
            <!-- Kontur: Góra, Lewo, Prawo -->
            <item android:bottom="-1dp">
                <shape>
                    <stroke android:width="1dp" android:color="#33000000" />
                    <corners android:topLeftRadius="8dp" android:topRightRadius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>