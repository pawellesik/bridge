<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <!-- Wypełnienie -->
            <item>
                <shape>
                    <solid android:color="#1A3026" />
                    <corners android:topLeftRadius="8dp" android:topRightRadius="8dp" />
                </shape>
            </item>
            <!-- Tylko górna krawędź (boki i dół ukryte przez ujemne marginesy) -->
            <item android:left="-1dp" android:right="-1dp" android:bottom="-1dp">
                <shape>
                    <stroke android:width="1dp" android:color="#4D000000" />
                    <corners android:topLeftRadius="8dp" android:topRightRadius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <!-- Wypełnienie -->
            <item>
                <shape>
                    <solid android:color="#D5D9A5" />
                    <corners android:topLeftRadius="8dp" android:topRightRadius="8dp" />
                </shape>
            </item>
            <!-- Tylko górna krawędź -->
            <item android:left="-1dp" android:right="-1dp" android:bottom="-1dp">
                <shape>
                    <stroke android:width="1dp" android:color="#4D000000" />
                    <corners android:topLeftRadius="8dp" android:topRightRadius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>