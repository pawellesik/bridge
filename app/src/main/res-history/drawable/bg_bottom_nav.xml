<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Linia rozdzielająca na górze -->
    <item>
        <shape>
            <solid android:color="#22FFFFFF"/>
        </shape>
    </item>

    <!-- Główne wypełnienie (bez linii na dole, aby zlało się z paskiem systemowym) -->
    <item
        android:top="1dp">
        <shape>
            <solid android:color="#0F170D"/>
        </shape>
    </item>

</layer-list>