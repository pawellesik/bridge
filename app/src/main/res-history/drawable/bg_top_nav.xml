<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Obramowanie -->
    <item>
        <shape>
            <solid android:color="#00000000"/>

            <stroke
                android:width="1dp"
                android:color="#33FFFFFF"/>
        </shape>
    </item>

    <!-- Wypełnienie zakrywające górny stroke -->
    <item
        android:bottom="1dp">
        <shape>
            <solid android:color="#0F2111"/>

        </shape>
    </item>

</layer-list>