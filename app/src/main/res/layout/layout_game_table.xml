<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game_table_gradient">

    <TextView
        android:id="@+id/name_north"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:text="@string/player_north"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="100dp"/> <!-- Adjusted to be below top_bar -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_hand_north"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/name_north"
        tools:listitem="@layout/item_card" />

    <!-- South Player Hand -->
    <TextView
        android:id="@+id/name_south"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:text="@string/player_south"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintBottom_toTopOf="@id/rv_hand_south"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="4dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_hand_south"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="72dp"
        android:padding="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:listitem="@layout/item_card" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/start_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/name_south"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rv_hand_north">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start"
            android:layout_width="260dp"
            android:layout_height="84dp"
            android:layout_margin="8dp"
            android:alpha="0.95"
            android:text="@string/Start"
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_green_button"
            app:backgroundTint="@null"
            app:cornerRadius="20dp"
            app:elevation="10dp"
            app:icon="@drawable/ic_arrow"
            app:iconGravity="textStart"
            app:iconPadding="16dp"
            app:iconSize="32dp"
            app:iconTint="@android:color/white"
            app:layout_constraintBottom_toTopOf="@+id/btn_deal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_deal"
            android:layout_width="240dp"
            android:layout_height="72dp"
            android:layout_margin="8dp"
            android:alpha="0.95"
            android:text="@string/deal"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_blue_button"
            app:backgroundTint="@null"
            app:cornerRadius="20dp"
            app:elevation="8dp"
            app:icon="@drawable/ic_cards"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconSize="28dp"
            app:iconTint="@android:color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btn_start" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_claim"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:layout_margin="4dp"
        android:alpha="0.95"
        android:background="@drawable/bg_green_button"
        android:text="@string/claim"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:backgroundTint="@null"
        app:cornerRadius="30dp"
        app:elevation="8dp"
        app:icon="@drawable/ic_take_rest"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="@id/name_south"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rv_hand_north"
        tools:visibility="visible" />

    <!-- Side Hand Placeholders (Stacks) -->
    <LinearLayout
        android:id="@+id/stack_west_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/table_center"
        app:layout_constraintBottom_toBottomOf="@id/table_center"
        android:layout_marginStart="8dp">
        <TextView
            android:id="@+id/name_west"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:text="@string/player_west"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginBottom="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/stack_east_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/table_center"
        app:layout_constraintBottom_toBottomOf="@id/table_center"
        android:layout_marginEnd="8dp">
        <TextView
            android:id="@+id/name_east"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:text="@string/player_east"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginBottom="4dp"/>
    </LinearLayout>

    <!-- Center Table -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/table_center"
        android:layout_width="220dp"
        android:layout_height="220dp"
        app:layout_constraintBottom_toTopOf="@id/name_south"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rv_hand_north"
        tools:visibility="visible">

        <!-- Played North -->
        <FrameLayout
            android:id="@+id/container_played_north"
            android:layout_width="70dp"
            android:layout_height="90dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Played South -->
        <FrameLayout
            android:id="@+id/container_played_south"
            android:layout_width="70dp"
            android:layout_height="90dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Played West -->
        <FrameLayout
            android:id="@+id/container_played_west"
            android:layout_width="70dp"
            android:layout_height="90dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Played East -->
        <FrameLayout
            android:id="@+id/container_played_east"
            android:layout_width="70dp"
            android:layout_height="90dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
