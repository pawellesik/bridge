<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B5E20"
    tools:context=".GameActivity">

    <!-- Top Status Bar (Scoreboard) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Left Info (Contract + Scores) -->
        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/game_contract_container"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <TextView
                    android:id="@+id/game_contract"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_contract_suit"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/we_score"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_marginTop="2dp"
                android:background="#1B5E20"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="@string/we_label"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:id="@+id/sn_score"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_marginTop="2dp"
                android:background="#1B5E20"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="@string/sn_label"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Middle Info -->
        <LinearLayout
            android:id="@+id/middle_info_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_middle_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="@string/score_label" />

            <TextView
                android:id="@+id/tv_middle_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_middle_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Right Bids (Cross Pattern) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/last_cards"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/n_last_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/w_last_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="4dp"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@+id/e_last_card"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/n_last_card" />

            <TextView
                android:id="@+id/e_last_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/w_last_card"
                app:layout_constraintTop_toTopOf="@id/w_last_card" />

            <TextView
                android:id="@+id/s_last_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/w_last_card" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/name_north"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:text="@string/player_north"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_hand_north"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/name_north"
        tools:listitem="@layout/item_card" />

    <!-- Center Table -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/table_center"
        android:layout_width="220dp"
        android:layout_height="220dp"
        app:layout_constraintTop_toBottomOf="@id/rv_hand_north"
        app:layout_constraintBottom_toTopOf="@id/name_south"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Played North -->
        <FrameLayout
            android:id="@+id/container_played_north"
            android:layout_width="70dp"
            android:layout_height="90dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Played South -->
        <FrameLayout
            android:id="@+id/container_played_south"
            android:layout_width="70dp"
            android:layout_height="90dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Played West -->
        <FrameLayout
            android:id="@+id/container_played_west"
            android:layout_width="70dp"
            android:layout_height="90dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Played East -->
        <FrameLayout
            android:id="@+id/container_played_east"
            android:layout_width="70dp"
            android:layout_height="90dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Side Hand Placeholders (Stacks) -->
    <LinearLayout
        android:id="@+id/stack_west_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/table_center"
        app:layout_constraintBottom_toBottomOf="@id/table_center"
        android:layout_marginStart="8dp">
        <TextView
            android:id="@+id/name_west"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:text="@string/player_west"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginBottom="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/stack_east_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/table_center"
        app:layout_constraintBottom_toBottomOf="@id/table_center"
        android:layout_marginEnd="8dp">
        <TextView
            android:id="@+id/name_east"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:text="@string/player_east"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginBottom="4dp"/>
    </LinearLayout>

    <!-- South Player Hand -->
    <TextView
        android:id="@+id/name_south"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:text="@string/player_south"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintBottom_toTopOf="@id/rv_hand_south"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="4dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_hand_south"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:listitem="@layout/item_card" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/start_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/name_south"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rv_hand_north">

        <Button
            android:id="@+id/btn_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:alpha="0.9"
            android:text="@string/Start"
            app:layout_constraintBottom_toTopOf="@+id/btn_deal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <Button
            android:id="@+id/btn_deal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:alpha="0.9"
            android:text="@string/deal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btn_start" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <Button
        android:id="@+id/btn_claim"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/claim"
        android:visibility="gone"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Results Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/results_overlay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#1B5E20"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <!-- Content (Player Hands) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_hands"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- North (Dummy) -->
            <LinearLayout
                android:id="@+id/layout_north_res"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_north"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_north_cards_res"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:minHeight="84dp"
                    android:background="@drawable/white_frame_in_bright_green"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp" />
            </LinearLayout>

            <!-- West (LHO) -->
            <LinearLayout
                android:id="@+id/layout_west_res"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                app:layout_constraintTop_toBottomOf="@id/layout_north_res"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/layout_east_res">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_west"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_west_cards_res"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:minHeight="84dp"
                    android:background="@drawable/white_frame_in_bright_green"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp" />
            </LinearLayout>

            <!-- East (RHO) -->
            <LinearLayout
                android:id="@+id/layout_east_res"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                app:layout_constraintTop_toBottomOf="@id/layout_north_res"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/layout_west_res">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_east"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_east_cards_res"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:minHeight="84dp"
                    android:background="@drawable/white_frame_in_bright_green"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp" />
            </LinearLayout>

            <!-- South (You) -->
            <LinearLayout
                android:id="@+id/layout_south_res"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layout_west_res">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_south"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_south_cards_res"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:minHeight="84dp"
                    android:background="@drawable/white_frame_in_bright_green"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_history"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            android:background="#C8E6C9"
            app:layout_constraintTop_toBottomOf="@id/layout_hands"
            app:layout_constraintBottom_toTopOf="@id/btn_new_deal">

            <TableLayout
                android:id="@+id/table_history_res"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:stretchColumns="0,1,2,3">

                <!-- Header Row -->
                <TableRow android:background="#A5D6A7">
                    <TextView android:text="@string/player_west" android:textColor="@color/black" android:textStyle="bold" android:gravity="center" android:padding="4dp"/>
                    <TextView android:text="@string/player_north" android:textColor="@color/black" android:textStyle="bold" android:gravity="center" android:padding="4dp"/>
                    <TextView android:text="@string/player_east" android:textColor="@color/black" android:textStyle="bold" android:gravity="center" android:padding="4dp"/>
                    <TextView android:text="@string/player_south" android:textColor="@color/black" android:textStyle="bold" android:gravity="center" android:padding="4dp"/>
                </TableRow>

            </TableLayout>
        </androidx.core.widget.NestedScrollView>

        <Button
            android:id="@+id/btn_new_deal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/new_deal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
