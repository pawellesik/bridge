<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B5E20"
    tools:context=".StartActivity">

    <!-- Language Container at top-right -->
    <LinearLayout
        android:id="@+id/lang_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btn_lang_en"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:padding="0dp"
            android:text="@string/lang_en"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            app:strokeColor="@android:color/white" />

        <Button
            android:id="@+id/btn_lang_pl"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:padding="0dp"
            android:text="@string/lang_pl"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            app:strokeColor="@android:color/white" />
    </LinearLayout>

    <TextView
        android:id="@+id/title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="@string/app_name"
        android:textColor="@android:color/white"
        android:textSize="56sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/menu_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_text">

        <!-- Quick Game -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start"
            android:layout_width="210dp"
            android:layout_height="54dp"
            android:layout_marginVertical="6dp"
            android:text="@string/quick_game"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_green_button"
            app:backgroundTint="@null"
            app:elevation="4dp"
            app:icon="@drawable/ic_arrow"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="#FFFFFF"
            app:iconTintMode="src_in" />

        <!-- Single -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_single"
            android:layout_width="210dp"
            android:layout_height="54dp"
            android:layout_marginVertical="6dp"
            android:text="@string/single_player"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_green_button"
            app:backgroundTint="@null"
            app:elevation="4dp"
            app:icon="@drawable/ic_singleplayer"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="#FFFFFF"
            app:iconTintMode="src_in" />

        <!-- Multiplayer -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_multiplayer"
            android:layout_width="210dp"
            android:layout_height="54dp"
            android:layout_marginVertical="6dp"
            android:text="@string/multiplayer"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_green_button"
            app:backgroundTint="@null"
            app:elevation="4dp"
            app:icon="@drawable/ic_multiplayer"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="#FFFFFF"
            app:iconTintMode="src_in" />

        <!-- History -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_history"
            android:layout_width="210dp"
            android:layout_height="54dp"
            android:layout_marginVertical="6dp"
            android:text="@string/history_games"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_green_button"
            app:backgroundTint="@null"
            app:elevation="4dp"
            app:icon="@drawable/ic_history"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="#FFFFFF"
            app:iconTintMode="src_in" />

        <!-- More -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_more"
            android:layout_width="210dp"
            android:layout_height="54dp"
            android:layout_marginVertical="6dp"
            android:text="@string/more"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_blue_button"
            app:backgroundTint="@null"
            app:elevation="4dp"
            app:icon="@drawable/ic_more"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="#FFFFFF"
            app:iconTintMode="src_in" />

        <!-- Hidden container for More options -->
        <LinearLayout
            android:id="@+id/more_options_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:gravity="center">

            <!-- Create Deal -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create_deal"
                android:layout_width="210dp"
                android:layout_height="54dp"
                android:layout_marginVertical="6dp"
                android:text="@string/create_deal"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_yellow_button"
                app:backgroundTint="@null"
                app:elevation="4dp"
                app:icon="@drawable/ic_add"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF"
                app:iconTintMode="src_in" />

            <!-- Settings -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_settings"
                android:layout_width="210dp"
                android:layout_height="54dp"
                android:layout_marginVertical="6dp"
                android:text="@string/settings"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_yellow_button"
                app:backgroundTint="@null"
                app:elevation="4dp"
                app:icon="@drawable/ic_settings"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF"
                app:iconTintMode="src_in" />

            <!-- About -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_about"
                android:layout_width="210dp"
                android:layout_height="54dp"
                android:layout_marginVertical="6dp"
                android:text="@string/about"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_yellow_button"
                app:backgroundTint="@null"
                app:elevation="4dp"
                app:icon="@drawable/ic_about"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF"
                app:iconTintMode="src_in" />

        </LinearLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>