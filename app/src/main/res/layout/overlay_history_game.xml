<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/history_game_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game_table_gradient"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone"
    tools:visibility="visible">

    <!-- Header (Black bar) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/history_game_header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_top_nav"
        android:elevation="50dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:translationZ="100dp"
        app:layout_constraintTop_toTopOf="parent">
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Cross Layout Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_hands_history_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/history_game_header_container">

        <!-- Column Guidelines -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guide_33"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.3333" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guide_66"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.6666" />

        <!-- CENTER: Bidding Box (Reference for everything) -->
        <LinearLayout
            android:id="@+id/layout_center_history"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:background="#D0E0E0E0"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guide_66"
            app:layout_constraintStart_toStartOf="@+id/guide_33"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="22dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#1A3026"
                    android:gravity="center"
                    android:text="W"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#C62828"
                    android:gravity="center"
                    android:text="N"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#1A3026"
                    android:gravity="center"
                    android:text="E"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#C62828"
                    android:gravity="center"
                    android:text="S"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_bidding_history_compact"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="4dp"
                android:textColor="@color/black"
                android:textSize="11sp"
                tools:text="Pas 1BA Pas Pas\nPas" />
        </LinearLayout>

        <!-- NORTH Cards -->
        <TextView
            android:id="@+id/tv_north_cards_history"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:background="#D0E0E0E0"
            android:padding="4dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintBottom_toTopOf="@+id/layout_center_history"
            app:layout_constraintEnd_toEndOf="@+id/layout_center_history"
            app:layout_constraintStart_toStartOf="@+id/layout_center_history"
            tools:text="♠ 10 4\n♥ D 4\n♦ 8 6 5 4 2\n♣ K 8 5 2" />

        <TextView
            android:id="@+id/label_north"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginBottom="2dp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/player_north"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            app:layout_constraintBottom_toTopOf="@+id/tv_north_cards_history"
            app:layout_constraintEnd_toEndOf="@+id/tv_north_cards_history"
            app:layout_constraintStart_toStartOf="@+id/tv_north_cards_history" />

        <!-- WEST Cards -->
        <TextView
            android:id="@+id/tv_west_cards_history"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:background="#D0E0E0E0"
            android:padding="4dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@+id/layout_center_history"
            app:layout_constraintEnd_toStartOf="@+id/layout_center_history"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/layout_center_history"
            tools:text="♠ W 7 6 5 2\n♥ 3\n♦ K 10 7\n♣ W 10 6 3" />

        <TextView
            android:id="@+id/label_west"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginBottom="2dp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/player_west"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            app:layout_constraintBottom_toTopOf="@+id/tv_west_cards_history"
            app:layout_constraintEnd_toEndOf="@+id/tv_west_cards_history"
            app:layout_constraintStart_toStartOf="@+id/tv_west_cards_history" />

        <!-- EAST Cards -->
        <TextView
            android:id="@+id/tv_east_cards_history"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:background="#D0E0E0E0"
            android:padding="4dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@+id/layout_center_history"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/layout_center_history"
            app:layout_constraintTop_toTopOf="@+id/layout_center_history"
            tools:text="♠ AK 3\n♥ W 10 9 5 2\n♦ AD 3\n♣ D 4" />

        <TextView
            android:id="@+id/label_east"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginBottom="2dp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/player_east"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            app:layout_constraintBottom_toTopOf="@+id/tv_east_cards_history"
            app:layout_constraintEnd_toEndOf="@+id/tv_east_cards_history"
            app:layout_constraintStart_toStartOf="@+id/tv_east_cards_history" />

        <!-- SOUTH Cards -->
        <TextView
            android:id="@+id/tv_south_cards_history"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:background="#D0E0E0E0"
            android:padding="4dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/layout_center_history"
            app:layout_constraintStart_toStartOf="@+id/layout_center_history"
            app:layout_constraintTop_toBottomOf="@+id/layout_center_history"
            tools:text="♠ D 9 8\n♥ AK 8 7 6\n♦ W 9\n♣ A 9 7" />

        <TextView
            android:id="@+id/label_south"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/player_south"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/tv_south_cards_history"
            app:layout_constraintStart_toStartOf="@+id/tv_south_cards_history"
            app:layout_constraintTop_toBottomOf="@+id/tv_south_cards_history" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/simulation_bar_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="2dp"
        app:cardBackgroundColor="#16321A"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/layout_hands_history_container"
        app:strokeColor="#1AFFFFFF"
        app:strokeWidth="1dp"
        tools:layout_editor_absoluteX="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="0dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_all_start_history"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:text="|&lt;"
                android:textColor="#80FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_first_trick_history"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:text="&lt;&lt;"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_prev_trick_history"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:text="&lt;"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_trick_info_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_settings_icon"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="0 / 13"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next_trick_history"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:text="&gt;"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_last_trick_history"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:text="&gt;&gt;"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_all_end_history"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:text="&gt;|"
                android:textColor="#80FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_table_history_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_bidding_container"
        android:padding="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/simulation_bar_history">

        <LinearLayout
            android:id="@+id/table_history_header_history"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@drawable/bg_bidding_table_header"
            android:orientation="horizontal"
            android:divider="@drawable/divider_white"
            android:showDividers="middle"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:gravity="center"
                android:padding="4dp"
                android:text="@string/history_col_name"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:gravity="center"
                android:padding="4dp"
                android:text="@string/history_col_contract"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="4dp"
                android:text="@string/history_col_my"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="4dp"
                android:text="@string/history_col_opps"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="4dp"
                android:text="@string/history_col_my"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="4dp"
                android:text="@string/history_col_opps"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_history_history"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="#D0E0E0E0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/table_history_header_history">

            <LinearLayout
                android:id="@+id/table_history_content_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
