<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Level Tabs area -->
    <LinearLayout
        android:id="@+id/ll_levels"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:paddingHorizontal="1dp"
        android:weightSum="7"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btn_level_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/sel_bidding_level"
            android:gravity="center"
            android:text="1"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_level_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/sel_bidding_level"
            android:gravity="center"
            android:text="2"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_level_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/sel_bidding_level"
            android:gravity="center"
            android:text="3"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_level_4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/sel_bidding_level"
            android:gravity="center"
            android:text="4"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_level_5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/sel_bidding_level"
            android:gravity="center"
            android:text="5"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_level_6"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/sel_bidding_level"
            android:gravity="center"
            android:text="6"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_level_7"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/sel_bidding_level"
            android:gravity="center"
            android:text="7"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Main Bidding Box Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_bidding_controls_box"
        android:paddingHorizontal="2dp"
        app:layout_constraintTop_toBottomOf="@id/ll_levels">

        <LinearLayout
            android:id="@+id/ll_main_controls"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Suits as card-like tiles -->
            <TextView
                android:id="@+id/bid_clubs"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="1dp"
                android:layout_weight="1"
                android:background="@drawable/bg_bid_control_button"
                android:drawablePadding="1dp"
                android:gravity="center"
                android:text="1"
                android:textColor="#388E3C"
                android:textSize="18sp"
                android:textStyle="bold"
                app:drawableEndCompat="@drawable/clubs" />

            <TextView
                android:id="@+id/bid_diamonds"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="1dp"
                android:layout_weight="1"
                android:background="@drawable/bg_bid_control_button"
                android:drawablePadding="1dp"
                android:gravity="center"
                android:text="1"
                android:textColor="#F57C00"
                android:textSize="18sp"
                android:textStyle="bold"
                app:drawableEndCompat="@drawable/diamonds" />

            <TextView
                android:id="@+id/bid_hearts"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="1dp"
                android:layout_weight="1"
                android:background="@drawable/bg_bid_control_button"
                android:drawablePadding="1dp"
                android:gravity="center"
                android:text="1"
                android:textColor="#C94B4B"
                android:textSize="18sp"
                android:textStyle="bold"
                app:drawableEndCompat="@drawable/heart" />

            <TextView
                android:id="@+id/bid_spades"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="1dp"
                android:layout_weight="1"
                android:background="@drawable/bg_bid_control_button"
                android:drawablePadding="1dp"
                android:gravity="center"
                android:text="1"
                android:textColor="#243D65"
                android:textSize="18sp"
                android:textStyle="bold"
                app:drawableEndCompat="@drawable/spades" />

            <TextView
                android:id="@+id/bid_nt"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="1dp"
                android:layout_weight="1.2"
                android:background="@drawable/bg_bid_control_button"
                android:gravity="center"
                android:text="1 NT"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_bid_double_toggle"
                android:layout_width="38dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="1dp"
                android:background="@drawable/bg_bid_control_button"
                android:gravity="center"
                android:text="X"
                android:textColor="#C62828"
                android:textSize="22sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_bid_pass"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="1dp"
                android:layout_weight="1.5"
                android:backgroundTint="#4D7C4F"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text="PASS"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="6dp" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>