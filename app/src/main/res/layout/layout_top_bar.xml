<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/top_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="96dp"
    android:padding="4dp">

    <!-- Left Info (Contract + Scores) -->
    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <LinearLayout
            android:id="@+id/game_contract_container"
            android:layout_width="70dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/game_contract"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iv_contract_suit"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/we_score"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="WE: 0" />

        <TextView
            android:id="@+id/sn_score"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="SN: 0" />
    </LinearLayout>

    <!-- Middle Info -->
    <LinearLayout
        android:id="@+id/middle_info_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tv_middle_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/score_label"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_middle_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_middle_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Right Bids (Cross Pattern) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/last_cards"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <!-- North Last Card -->
        <LinearLayout
            android:id="@+id/n_last_card"
            android:layout_width="50dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_suit_n"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="2dp" />

            <TextView
                android:id="@+id/tv_rank_n"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- West Last Card -->
        <LinearLayout
            android:id="@+id/w_last_card"
            android:layout_width="50dp"
            android:layout_height="24dp"
            android:layout_marginTop="1dp"
            android:layout_marginEnd="2dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="0dp"
            app:layout_constraintEnd_toStartOf="@+id/e_last_card"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/n_last_card">

            <ImageView
                android:id="@+id/iv_suit_w"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="2dp" />

            <TextView
                android:id="@+id/tv_rank_w"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- East Last Card -->
        <LinearLayout
            android:id="@+id/e_last_card"
            android:layout_width="50dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/w_last_card"
            app:layout_constraintTop_toTopOf="@id/w_last_card">

            <ImageView
                android:id="@+id/iv_suit_e"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="2dp" />

            <TextView
                android:id="@+id/tv_rank_e"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- South Last Card -->
        <LinearLayout
            android:id="@+id/s_last_card"
            android:layout_width="50dp"
            android:layout_height="24dp"
            android:layout_marginTop="1dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/w_last_card">

            <ImageView
                android:id="@+id/iv_suit_s"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="2dp" />

            <TextView
                android:id="@+id/tv_rank_s"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
