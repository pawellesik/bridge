<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B5E20">

    <!-- Top Status Bar (Scoreboard) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Left Info (Contract + Scores) -->
        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/game_contract_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="2dp">

                <TextView
                    android:id="@+id/game_contract"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_contract_suit"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="4dp"
                    android:contentDescription="@string/suit_desc" />
            </LinearLayout>

            <TextView
                android:id="@+id/we_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="#1B5E20"
                android:padding="2dp"
                android:text="WE: 0"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:id="@+id/sn_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="#1B5E20"
                android:padding="2dp"
                android:text="SN: 0"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Middle Info -->
        <LinearLayout
            android:id="@+id/middle_info_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_middle_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_middle_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:text="score: 0"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_middle_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Right Bids (Cross Pattern) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/last_cards"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/n_last_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/white_frame_in_bright_green"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/w_last_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/white_frame_in_bright_green"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@+id/e_last_card"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/n_last_card" />

            <TextView
                android:id="@+id/e_last_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/white_frame_in_bright_green"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/w_last_card"
                app:layout_constraintTop_toTopOf="@id/w_last_card" />

            <TextView
                android:id="@+id/s_last_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="@drawable/white_frame_in_bright_green"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/w_last_card" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content (Player Hands) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_hands"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <!-- North (Dummy) -->
        <LinearLayout
            android:id="@+id/layout_north"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="North"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_north_cards"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:minHeight="84dp"
                android:background="@drawable/white_frame_in_bright_green"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />
        </LinearLayout>

        <!-- West (LHO) -->
        <LinearLayout
            android:id="@+id/layout_west"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            app:layout_constraintTop_toBottomOf="@id/layout_north"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/layout_east">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="West"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@android:color/white"/>

            <TextView
                android:id="@+id/tv_west_cards"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:minHeight="84dp"
                android:background="@drawable/white_frame_in_bright_green"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />
        </LinearLayout>

        <!-- East (RHO) -->
        <LinearLayout
            android:id="@+id/layout_east"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            app:layout_constraintTop_toBottomOf="@id/layout_north"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/layout_west">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="East"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@android:color/white"/>

            <TextView
                android:id="@+id/tv_east_cards"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:minHeight="84dp"
                android:background="@drawable/white_frame_in_bright_green"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />
        </LinearLayout>

        <!-- South (You) -->
        <LinearLayout
            android:id="@+id/layout_south"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layout_west">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="South"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_south_cards"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:minHeight="84dp"
                android:background="@drawable/white_frame_in_bright_green"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/tx_history"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:background="#C8E6C9"
        app:layout_constraintTop_toBottomOf="@id/layout_hands"
        app:layout_constraintBottom_toTopOf="@id/btn_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TableLayout
            android:id="@+id/table_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:stretchColumns="0,1,2,3">

            <!-- Header Row -->
            <TableRow android:background="#A5D6A7">
                <TextView android:text="West" android:textColor="@color/black" android:textStyle="bold" android:gravity="center" android:padding="4dp"/>
                <TextView android:text="North" android:textColor="@color/black" android:textStyle="bold" android:gravity="center" android:padding="4dp"/>
                <TextView android:text="East" android:textColor="@color/black" android:textStyle="bold" android:gravity="center" android:padding="4dp"/>
                <TextView android:text="South" android:textColor="@color/black" android:textStyle="bold" android:gravity="center" android:padding="4dp"/>
            </TableRow>

        </TableLayout>
    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Back to Game"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
