<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bidding_history_outer_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bidding_container"
    android:padding="1dp">

    <!-- Table Header with white dividers and localized names -->
    <LinearLayout
        android:id="@+id/bidding_header"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@drawable/bg_bidding_table_header"
        android:orientation="horizontal"
        android:weightSum="4"
        android:divider="@drawable/divider_white"
        android:dividerPadding="0dp"
        android:showDividers="middle"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/player_west"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/player_north"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/player_east"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/player_south"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_bidding_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_bidding_history_list"
        android:overScrollMode="never"
        android:scrollbars="vertical"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        android:clipToOutline="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bidding_header" />

</androidx.constraintlayout.widget.ConstraintLayout>