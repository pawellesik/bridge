<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/results_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B5E20"
    android:visibility="gone">

    <!-- Content (Player Hands) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_hands"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- North (Dummy) -->
        <LinearLayout
            android:id="@+id/layout_north_res"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player_north"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_north_cards_res"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bright_green_frame_black"
                android:lineSpacingExtra="4dp"
                android:minHeight="84dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textColor="@color/black"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- West (LHO) -->
        <LinearLayout
            android:id="@+id/layout_west_res"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toStartOf="@+id/layout_east_res"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_north_res">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player_west"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_west_cards_res"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bright_green_frame_black"
                android:lineSpacingExtra="4dp"
                android:minHeight="84dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textColor="@color/black"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- East (RHO) -->
        <LinearLayout
            android:id="@+id/layout_east_res"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/layout_west_res"
            app:layout_constraintTop_toBottomOf="@id/layout_north_res">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player_east"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_east_cards_res"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bright_green_frame_black"
                android:lineSpacingExtra="4dp"
                android:minHeight="84dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textColor="@color/black"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- South (You) -->
        <LinearLayout
            android:id="@+id/layout_south_res"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layout_west_res">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player_south"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_south_cards_res"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bright_green_frame_black"
                android:lineSpacingExtra="4dp"
                android:minHeight="84dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textColor="@color/black"
                android:textSize="14sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Simulation Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/simulation_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="#2E7D32"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/layout_hands">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_first_trick"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:text="&lt;&lt;"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:rippleColor="#40FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_prev_trick"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:text="&lt;"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:rippleColor="#40FFFFFF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/bright_green_frame_black"
                android:backgroundTint="#1B5E20"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/trick_label"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_trick_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" / 13"
                    android:textColor="#BDBDBD"
                    android:textSize="14sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next_trick"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:text="&gt;"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:rippleColor="#40FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_last_trick"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:text="&gt;&gt;"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:rippleColor="#40FFFFFF" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- History Header (Sticky) -->
    <LinearLayout
        android:id="@+id/table_history_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        android:background="#A5D6A7"
        android:divider="@drawable/history_divider"
        android:orientation="horizontal"
        android:showDividers="middle"
        app:layout_constraintTop_toBottomOf="@+id/simulation_bar">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="4dp"
            android:text="@string/player_west"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="4dp"
            android:text="@string/player_north"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="4dp"
            android:text="@string/player_east"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="4dp"
            android:text="@string/player_south"
            android:textColor="@color/black"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="8dp"
        android:background="#C8E6C9"
        app:layout_constraintBottom_toTopOf="@id/results_buttons_container"
        app:layout_constraintTop_toBottomOf="@+id/table_history_header"
        tools:layout_editor_absoluteX="8dp"
        tools:visibility="visible">

        <LinearLayout
            android:id="@+id/table_history_res"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/history_divider"
            android:orientation="vertical"
            android:showDividers="middle"></LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/results_buttons_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_game"
            android:layout_width="85dp"
            android:layout_height="48dp"
            android:layout_marginEnd="4dp"
            android:alpha="0.95"
            android:background="@drawable/bg_yellow_button"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:text="@string/save"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="24dp"
            app:elevation="4dp"
            app:icon="@drawable/ic_star"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="16dp"
            app:iconTint="@android:color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_auto_replay"
            android:layout_width="145dp"
            android:layout_height="48dp"
            android:layout_marginEnd="4dp"
            android:alpha="0.95"
            android:background="@drawable/bg_green_button"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:text="@string/auto_play_deal"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="24dp"
            app:elevation="4dp"
            app:icon="@drawable/ic_autogame_foreground"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="24dp"
            app:iconTint="@android:color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_new_deal"
            android:layout_width="115dp"
            android:layout_height="48dp"
            android:alpha="0.95"
            android:background="@drawable/bg_blue_button"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:text="@string/new_deal"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="24dp"
            app:elevation="4dp"
            app:icon="@drawable/ic_cards"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="16dp"
            app:iconTint="@android:color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
