<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State when button is pressed -->
    <item android:drawable="@drawable/bg_green_button_pressed" android:state_pressed="true" />

    <!-- State when button is focused (for keyboard/DPAD navigation) -->
    <item android:drawable="@drawable/bg_green_button_pressed" android:state_focused="true" />

    <!-- Default state -->
    <item android:drawable="@drawable/bg_green_button_normal" />
</selector>